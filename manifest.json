{
  "manifest_version": 3,
  "name": "Tab Search",
  "version": "1.0.16",
  "description": "Search through all opened tabs quickly and easily",
  "permissions": [
    "tabs",
    "activeTab",
    "windows"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; img-src 'self'  https:"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Search Tabs",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
