{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.1.1",
  "default_locale": "en",
  "description": "__MSG_appDescription__",
  "permissions": [
    "tabs",
    "activeTab",
    "windows",
    "storage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; img-src 'self'  https:"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_defaultTitle__",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
